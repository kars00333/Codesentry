{
  "name": "codesentry-backend",
  "version": "1.0.0",
  "description": "AI-powered GitHub PR code review bot",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "dev": "node --watch src/index.js",
    "worker": "node --watch src/worker.js",
    "start": "node src/index.js",
    "db:generate": "npx prisma generate",
    "db:push": "npx prisma db push",
    "db:migrate": "npx prisma migrate dev",
    "db:studio": "npx prisma studio"
  },
  "dependencies": {
    "@octokit/app": "^15.1.2",
    "@octokit/rest": "^21.1.1",
    "@prisma/client": "^6.9.0",
    "bullmq": "^5.34.8",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "ioredis": "^5.6.1",
    "parse-diff": "^0.11.1"
  },
  "devDependencies": {
    "prisma": "^6.9.0"
  }
}
