# Codesentry Backend Environment Variables

# GitHub App Configuration
# Get these from https://github.com/settings/apps
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
WEBHOOK_SECRET=your_webhook_secret_here

# Ollama (self-hosted LLM)
# Defaults shown below are used if these are unset
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# Database (must already exist — see "Local Services Setup" in README)
DATABASE_URL="postgresql://user:password@localhost:5432/codesentry?schema=public"

# Redis (for BullMQ job queue)
REDIS_URL="redis://localhost:6379"

# Server
PORT=3001
NODE_ENV=development
